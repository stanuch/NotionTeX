{
  "manifest_version": 3,
  "name": "NotionTeX",
  "version": "2.0.1",
  "description": "Seamlessly converts LaTeX-style math into native Notion inline and block equations.",
  "minimum_chrome_version": "109",
  "icons": {
    "16": "assets/icons/icon16.png",
    "32": "assets/icons/icon32.png",
    "48": "assets/icons/icon48.png",
    "128": "assets/icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "contextMenus"
  ],
  "host_permissions": [
    "https://www.notion.so/*",
    "https://*.notion.site/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.notion.so/*",
        "https://*.notion.site/*"
      ],
      "js": [
        "src/content.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "convert_inline_equations": {
      "suggested_key": {
        "default": "Ctrl+M",
        "mac": "Command+Shift+M"
      },
      "description": "Trigger Math Conversion"
    }
  },
  "action": {
    "default_icon": {
      "16": "assets/icons/icon16.png",
      "32": "assets/icons/icon32.png",
      "48": "assets/icons/icon48.png",
      "128": "assets/icons/icon128.png"
    },
    "default_title": "NotionTeX"
  }
}